# ---- Core ----
ENV=dev
LOG_LEVEL=INFO

# ---- Database ----
DATABASE_URL=sqlite:///./stocksense.db
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/stocksense

# ---- Cache / rate limiting ----
REDIS_URL=
RATE_LIMIT_PER_MINUTE=120
CACHE_TTL_QUOTE_S=60
CACHE_TTL_HISTORY_S=21600
CACHE_TTL_SEARCH_S=86400

# ---- Providers ----
SEED_FALLBACK=true
PROVIDER_TIMEOUT_S=8
NSE_ENABLED=true

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- ML ----
TRAIN_MAX_RANGE_YEARS=10
MAX_CONCURRENT_TRAINS=4

# ---- Scheduler ----
SCHEDULER_ENABLED=true

# ---- Artifacts (R2/S3, roadmap R2.9) ----
MODEL_ARTIFACTS_BUCKET=
