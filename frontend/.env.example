# StockSense AI — Frontend environment
#
# Dev: leave VITE_API_BASE unset to use the Vite dev proxy
#      (configured in vite.config.ts) which forwards /api/* to
#      http://localhost:8000 (your local FastAPI backend).
#
# Production (Netlify build env): set this to your deployed API origin.
# Example: https://api.stocksense.app/api/v1
VITE_API_BASE=

# Optional: override the local dev proxy target (defaults to http://localhost:8000)
# API_PROXY_TARGET=http://localhost:8000

# Optional: surface the app version in the sidebar
VITE_APP_VERSION=0.1.0
